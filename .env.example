# JWT
JWT_SECRET=
JWT_REFRESH_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4001/auth/google/callback

# MongoDB (auth-service only)
MONGODB_URI=mongodb://localhost:27017/reclaim_auth

# PostgreSQL (all other services)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=reclaim

# S3 / MinIO (image storage)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=reclaim-images
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Email
SENDGRID_API_KEY=
EMAIL_FROM=noreply@reclaim.com

# App
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Service URLs (for inter-service communication)
AUTH_SERVICE_URL=http://localhost:4001
USER_SERVICE_URL=http://localhost:4002
LISTING_SERVICE_URL=http://localhost:4003
MEDIA_SERVICE_URL=http://localhost:4004
MATCH_SERVICE_URL=http://localhost:4005
CLAIM_SERVICE_URL=http://localhost:4006
CHAT_SERVICE_URL=http://localhost:4007
NOTIFICATION_SERVICE_URL=http://localhost:4008
SEARCH_SERVICE_URL=http://localhost:4009
ADMIN_SERVICE_URL=http://localhost:4010
RESOLUTION_SERVICE_URL=http://localhost:4011